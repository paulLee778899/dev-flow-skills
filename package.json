{
  "name": "dev-flow-skills",
  "version": "0.1.25",
  "description": "Governed development-flow skills for AI coding agents with independent CR, Loop Engineering delivery loops, read-only triage, and approved scheduler automation.",
  "type": "module",
  "bin": {
    "dev-flow": "bin/dev-flow.mjs"
  },
  "files": [
    ".opencode",
    ".codex-plugin",
    ".codex",
    "commands",
    "skills",
    "bin",
    "scripts",
    "install",
    "docs",
    "examples",
    "README.md",
    "CONTRIBUTING.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "doctor": "node bin/dev-flow.mjs doctor --target .",
    "dry-run:global": "node bin/dev-flow.mjs install --global --dry-run",
    "dry-run:local": "node bin/dev-flow.mjs install --target . --dry-run",
    "update:all": "node bin/dev-flow.mjs update --global && node bin/dev-flow.mjs update-codex && node bin/dev-flow.mjs update-claude"
  },
  "keywords": [
    "opencode",
    "ai-agent",
    "skills",
    "dev-flow",
    "loop",
    "triage",
    "scheduler",
    "automation",
    "workflow"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/paulLee778899/dev-flow-skills.git"
  },
  "bugs": {
    "url": "https://github.com/paulLee778899/dev-flow-skills/issues"
  },
  "homepage": "https://github.com/paulLee778899/dev-flow-skills#readme",
  "license": "MIT"
}
